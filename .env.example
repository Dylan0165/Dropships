# ═══════════════════════════════════════════════════════════════
# Dropshipping v0.1 Tool — Environment Configuration
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.

# ── DeepSeek AI (Primary AI Engine) ──────────────────────────
# Get your API key at https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Optional: Override DeepSeek base URL (for proxy or self-hosted)
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# Enable DeepSeek provider explicitly (auto-detected if DEEPSEEK_API_KEY is set)
# CLAUDE_CODE_USE_DEEPSEEK=1

# ── Model Overrides (Optional) ───────────────────────────────
# Override default models for specific roles
# ANTHROPIC_MODEL=deepseek-chat
# ANTHROPIC_DEFAULT_SONNET_MODEL=deepseek-chat
# ANTHROPIC_DEFAULT_OPUS_MODEL=deepseek-reasoner
# ANTHROPIC_DEFAULT_HAIKU_MODEL=deepseek-chat

# ── Pipeline Configuration ───────────────────────────────────
# Path overrides (auto-detected from workspace root)
# SKILLS_PATH=/absolute/path/to/Skillslibrary
# COMPONENTS_PATH=/absolute/path/to/Websitecomponentscodes
# CLAUDE_CODE_MAIN=/absolute/path/to/claude-code-main/src/main.tsx

# ── Pipeline Agent Thresholds ────────────────────────────────
# Trend Agent
TREND_MIN_VIRAL_SCORE=60
TREND_MIN_SOURCES=3
TREND_MAX_RESULTS=10

# Product Agent
PRODUCT_MIN_MARGIN_PERCENT=40
PRODUCT_MAX_SHIPPING_DAYS=15
PRODUCT_MIN_SUPPLIER_RATING=4.0

# Brand Agent
BRAND_NAME_MAX_LENGTH=20
BRAND_SLOGAN_MAX_LENGTH=60

# Store Builder
STORE_MIN_LIGHTHOUSE_SCORE=80
STORE_MAX_LOAD_TIME_MS=3000

# Ads Agent
ADS_MIN_HOOKS=3
ADS_MIN_COPY_VARIANTS=2
ADS_MAX_PRIMARY_TEXT=125
ADS_VIDEO_DURATION=30
ADS_VIDEO_SCENES=4
ADS_MIN_TARGETING_INTERESTS=3

# Video Inspiration Agent
VIDEO_MIN_VIEWS=10000
VIDEO_MIN_ENGAGEMENT_RATE=3.0
VIDEO_MIN_CONFIDENCE=50
VIDEO_TREND_WINDOW_DAYS=30

# ── Reviewer Thresholds ──────────────────────────────────────
REVIEWER_MIN_SCORE=70
REVIEWER_AUTO_APPROVE_ABOVE=90
REVIEWER_AUTO_REJECT_BELOW=40

# ── UIcontrol Dashboard ──────────────────────────────────────
PORT=3001
# VITE_PORT=5173

# ── Store Platform ────────────────────────────────────────────
# STORE_PORT=3002
# STORE_DOMAIN=localhost

# ── Multimodal (Future) ──────────────────────────────────────
# Enable when DeepSeek adds vision/video support
# DEEPSEEK_MULTIMODAL_ENABLED=1
# DEEPSEEK_MULTIMODAL_MODEL=deepseek-vision

# ── Security ──────────────────────────────────────────────────
# Rate limiting
# RATE_LIMIT_MESSAGES_PER_MIN=30
# RATE_LIMIT_PIPELINE_PER_HOUR=5

# ── Anthropic (Optional — for fallback/comparison) ───────────
# Only needed if you want to use Claude models alongside DeepSeek
# ANTHROPIC_API_KEY=sk-ant-xxxxx
