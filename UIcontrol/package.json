{
  "name": "dropship-uicontrol",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently --kill-others-on-fail -n server,platform,ui -c cyan,green,blue \"tsx watch src/server/index.ts\" \"tsx watch src/server/store-platform.ts\" \"npm run dev:ui\"",
    "dev:ui": "wait-on http://localhost:3001/api/health && vite --port 5173",
    "build": "vite build",
    "server": "tsx src/server/index.ts",
    "store-platform": "tsx src/server/store-platform.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@xyflow/react": "^12.3.0",
    "better-sqlite3": "^12.8.0",
    "clsx": "^2.1.0",
    "date-fns": "^4.1.0",
    "express": "^4.19.0",
    "lucide-react": "^0.383.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "uuid": "^10.0.0",
    "ws": "^8.18.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^4.17.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^8.2.0",
    "dotenv": "^17.3.1",
    "jsdom": "^29.0.1",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vitest": "^4.1.2",
    "wait-on": "^9.0.4"
  }
}
