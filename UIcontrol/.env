# ── LLM Provider (schakelbaar tussen Ollama en DeepSeek) ──────────────────────
# TESTING — lokaal Ollama model (geen kosten):
LLM_BASE_URL=http://192.168.121.122:11434/v1
LLM_MODEL=qwen2.5:14b
LLM_MODEL_EXECUTOR=qwen2.5:14b
LLM_MODEL_REVIEWER=qwen2.5:14b
LLM_API_KEY=

# PRODUCTIE — uncomment deze drie en comment bovenstaande:
# LLM_BASE_URL=https://api.deepseek.com
# LLM_MODEL=deepseek-chat
# LLM_API_KEY=sk-jouw-deepseek-key

# Legacy key (Trendscraper gebruikt dit nog direct)
DEEPSEEK_API_KEY=sk-0f965ac453c34de380ef160239814a7d

# ── Store instellingen ─────────────────────────────────────────
MAX_PRODUCTS_PER_STORE=3

PORT=3001
VITE_TRENDSCRAPER_URL=http://localhost:8001
TRENDSCRAPER_URL=http://localhost:8001
PLATFORM_API_URL=http://localhost:3002
INSPECTOR_URL=http://localhost:8002
DATABASE_PATH=./data/dropship.db
NICHE_MIN_SCORE=75
NICHE_TWIJFEL_MIN=60
PRODUCT_MIN_MARGE=15
PRODUCT_MIN_MARGE_FACTOR=3.0
PRODUCT_MAX_LEVERTIJD=5
GROWTH_KILL_ROAS=1.5
GROWTH_KILL_DAYS=7
GROWTH_SCALE_ROAS=3.0

# ── Store deployment ───────────────────────────────────────────
# Leave STORE_SERVER_HOST empty for LOCAL mode (writes to ./data/stores/).
# Set it to your VPS IP/host to enable REMOTE mode (npm build + scp + nginx reload).
STORE_SERVER_HOST=
STORE_SERVER_USER=deploy
STORE_SSH_KEY_PATH=
STORE_BASE_DOMAIN=jouwdomein.nl

# ── Mollie Checkout ────────────────────────────────────────────
# Haal op via: mollie.com → Dashboard → Developers → API-sleutels
# Leeg laten = mock-modus (checkout URL = https://mollie.com/checkout/test)
MOLLIE_API_KEY=

# ── Replicate (Flux 1.1 Pro beeldgeneratie) ────────────────────
# Haal op via: replicate.com → Account → API tokens
# Leeg laten = mock-modus (placeholder afbeeldingen)
REPLICATE_API_TOKEN=

# ── OpenAI (GPT-image-1 beeldgeneratie) ───────────────────────
# Haal op via: platform.openai.com → API keys
# Leeg laten = wordt overgeslagen (Flux wordt gebruikt als fallback)
OPENAI_API_KEY=

# ── Beeldgeneratie provider ────────────────────────────────────
# 'flux' = Replicate eerst (standaard)
# 'openai' = OpenAI eerst, Flux als fallback
IMAGE_PROVIDER=flux

# ── Microsoft Clarity analytics ───────────────────────────────
# Haal op via: clarity.microsoft.com → nieuw project
# Leeg laten = geen tracking
CLARITY_PROJECT_ID=

# ── Meta Ads API v21.0 ─────────────────────────────────────────
# Haal op via: developers.facebook.com → Marketing API
# Leeg laten = mock-modus (dummy campaign IDs)
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=
META_PAGE_ID=
META_PIXEL_ID=

# ── ApprovalApp ────────────────────────────────────────────────
APPROVAL_PIN=0000

# ── WhatsApp Cloud API ─────────────────────────────────────────
# Haal op via: developers.facebook.com → WhatsApp → Getting Started
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_TO=31612345678
APPROVAL_APP_URL=http://localhost:5174
