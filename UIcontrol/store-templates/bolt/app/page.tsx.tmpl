'use client';

interface Product { id: string; title: string; image: string; price: number; compareAtPrice?: number; badge?: string; description?: string }
const PRODUCTS: Product[] = {{PRODUCTS_JSON}};
const PRIMARY = '{{PRIMARY}}';
const ACCENT  = '{{ACCENT}}';

export default function Home() {
  const year = new Date().getFullYear();
  return (
    <div style={{ background: '#0a0a0a', color: '#fff', minHeight: '100vh', fontFamily: 'inherit' }}>

      {/* Nav */}
      <nav style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center', padding: '1.25rem 2.5rem', background: '#111', borderBottom: `2px solid ${PRIMARY}` }}>
        <span style={{ fontWeight: 900, fontSize: '1.2rem', letterSpacing: '-0.02em', color: PRIMARY }}>{{BRAND_NAME}}</span>
        <div style={{ display: 'flex', gap: '2rem' }}>
          <a href="#products" style={{ color: '#ccc', fontSize: '0.75rem', letterSpacing: '0.15em', textTransform: 'uppercase', textDecoration: 'none', fontWeight: 600 }}>Shop</a>
          <a href="#contact" style={{ color: '#ccc', fontSize: '0.75rem', letterSpacing: '0.15em', textTransform: 'uppercase', textDecoration: 'none', fontWeight: 600 }}>Contact</a>
        </div>
      </nav>

      {/* Hero — full viewport, energy */}
      <section style={{ minHeight: '85vh', display: 'flex', flexDirection: 'column', justifyContent: 'center', padding: '4rem 2.5rem', position: 'relative', overflow: 'hidden', background: `linear-gradient(135deg, #111 0%, #1a1a1a 100%)` }}>
        <div style={{ position: 'absolute', top: 0, right: 0, width: '40%', height: '100%', background: `linear-gradient(to left, ${PRIMARY}22, transparent)` }} />
        <p style={{ color: ACCENT, fontSize: '0.7rem', letterSpacing: '0.4em', textTransform: 'uppercase', marginBottom: '1rem', fontWeight: 800 }}>&#9889; Performance Gear</p>
        <h1 style={{ fontSize: 'clamp(3rem,10vw,8rem)', fontWeight: 900, lineHeight: 0.9, letterSpacing: '-0.04em', margin: '0 0 1.5rem', textTransform: 'uppercase' }}>
          {{HERO_HEADLINE}}
        </h1>
        <p style={{ color: 'rgba(255,255,255,0.55)', fontSize: '1.1rem', maxWidth: '38ch', lineHeight: 1.5, marginBottom: '2.5rem' }}>{{SLOGAN}}</p>
        <div style={{ display: 'flex', gap: '1rem', flexWrap: 'wrap' }}>
          <a href="#products" style={{ display: 'inline-flex', alignItems: 'center', gap: '0.5rem', background: PRIMARY, color: '#fff', fontWeight: 800, padding: '1rem 2.5rem', fontSize: '0.8rem', letterSpacing: '0.15em', textTransform: 'uppercase', textDecoration: 'none' }}>
            Shop Nu &#8594;
          </a>
          <div style={{ display: 'flex', alignItems: 'center', gap: '0.5rem', color: 'rgba(255,255,255,0.4)', fontSize: '0.75rem' }}>
            <span style={{ color: ACCENT }}>&#9733;&#9733;&#9733;&#9733;&#9733;</span> 10.000+ tevreden klanten
          </div>
        </div>
        {/* Urgency */}
        <div style={{ marginTop: '2rem', display: 'inline-flex', alignItems: 'center', gap: '0.75rem', background: `${ACCENT}22`, border: `1px solid ${ACCENT}44`, padding: '0.6rem 1.25rem', borderRadius: '4px' }}>
          <span style={{ color: ACCENT, fontSize: '0.75rem', fontWeight: 800, textTransform: 'uppercase', letterSpacing: '0.1em' }}>&#9889; Beperkte voorraad</span>
          <span style={{ color: 'rgba(255,255,255,0.5)', fontSize: '0.75rem' }}>Besteld v&#243;&#243;r 22:00 = morgen in huis</span>
        </div>
      </section>

      {/* USP bar */}
      <div style={{ background: PRIMARY, padding: '1rem 2.5rem', display: 'flex', gap: '3rem', overflowX: 'auto', justifyContent: 'center', flexWrap: 'wrap' }}>
        {['{{USP_1_TITLE}}', '{{USP_2_TITLE}}', '{{USP_3_TITLE}}'].map((u,i) => (
          <span key={i} style={{ color: '#fff', fontSize: '0.7rem', letterSpacing: '0.2em', textTransform: 'uppercase', fontWeight: 700, whiteSpace: 'nowrap' }}>&#10003; {u}</span>
        ))}
      </div>

      {/* Products */}
      <section id="products" style={{ padding: '5rem 2.5rem' }}>
        <h2 style={{ fontSize: '2rem', fontWeight: 900, textTransform: 'uppercase', letterSpacing: '-0.02em', marginBottom: '2.5rem', borderLeft: `4px solid ${PRIMARY}`, paddingLeft: '1rem' }}>Gear Up</h2>
        <div style={{ display: 'grid', gridTemplateColumns: 'repeat(auto-fill,minmax(260px,1fr))', gap: '1.5rem' }}>
          {PRODUCTS.map((p,i) => (
            <div key={i} style={{ background: '#111', border: '1px solid #222', overflow: 'hidden', cursor: 'pointer', transition: 'border-color 0.2s' }}
              onMouseEnter={e => { (e.currentTarget as HTMLDivElement).style.borderColor = PRIMARY }}
              onMouseLeave={e => { (e.currentTarget as HTMLDivElement).style.borderColor = '#222' }}>
              <div style={{ aspectRatio: '1/1', overflow: 'hidden', background: '#1a1a1a', position: 'relative' }}>
                {p.image && <img src={p.image} alt={p.title} style={{ width: '100%', height: '100%', objectFit: 'cover', transition: 'transform 0.4s ease' }}
                  onMouseEnter={e => { (e.currentTarget as HTMLImageElement).style.transform = 'scale(1.06)' }}
                  onMouseLeave={e => { (e.currentTarget as HTMLImageElement).style.transform = 'scale(1)' }} />}
                {p.badge && <span style={{ position: 'absolute', top: '0.75rem', left: '0.75rem', background: ACCENT, color: '#000', fontSize: '0.65rem', fontWeight: 800, padding: '0.2rem 0.5rem', textTransform: 'uppercase', letterSpacing: '0.08em' }}>{p.badge}</span>}
              </div>
              <div style={{ padding: '1.25rem' }}>
                <p style={{ margin: '0 0 0.5rem', fontWeight: 700, fontSize: '0.9rem', textTransform: 'uppercase', letterSpacing: '0.05em' }}>{p.title}</p>
                <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center' }}>
                  <div>
                    <span style={{ fontWeight: 800, fontSize: '1.1rem', color: PRIMARY }}>&#8364;{p.price.toFixed(2)}</span>
                    {p.compareAtPrice && <span style={{ color: '#555', fontSize: '0.85rem', textDecoration: 'line-through', marginLeft: '0.5rem' }}>&#8364;{p.compareAtPrice.toFixed(2)}</span>}
                  </div>
                  <button style={{ background: PRIMARY, color: '#fff', border: 'none', padding: '0.5rem 1rem', fontSize: '0.7rem', fontWeight: 800, textTransform: 'uppercase', letterSpacing: '0.1em', cursor: 'pointer' }}>
                    Kopen
                  </button>
                </div>
              </div>
            </div>
          ))}
        </div>
      </section>

      {/* Reviews */}
      <section style={{ padding: '4rem 2.5rem', background: '#111', borderTop: `2px solid ${PRIMARY}` }}>
        <h2 style={{ fontSize: '1.5rem', fontWeight: 900, textTransform: 'uppercase', marginBottom: '2rem' }}>Community</h2>
        <div style={{ display: 'grid', gridTemplateColumns: 'repeat(auto-fit,minmax(240px,1fr))', gap: '1.5rem' }}>
          {[
            { n: 'Marc R.',   s: 5, t: 'Beste aankoop van het jaar. Kwaliteit is top!' },
            { n: 'Julia K.',  s: 5, t: 'Snel geleverd, verpakking netjes, product geweldig.' },
            { n: 'Daan V.',   s: 5, t: 'Gebruik het dagelijks &#8212; echt een verschil.' },
          ].map((r,i) => (
            <div key={i} style={{ background: '#1a1a1a', padding: '1.5rem', borderLeft: `3px solid ${PRIMARY}` }}>
              <div style={{ color: ACCENT, marginBottom: '0.75rem', fontSize: '0.85rem' }}>{'★'.repeat(r.s)}</div>
              <p style={{ color: 'rgba(255,255,255,0.65)', fontSize: '0.875rem', lineHeight: 1.6, marginBottom: '0.75rem' }} dangerouslySetInnerHTML={{ __html: `"${r.t}"` }} />
              <span style={{ fontWeight: 700, fontSize: '0.8rem', color: PRIMARY }}>{r.n}</span>
            </div>
          ))}
        </div>
      </section>

      {/* Footer */}
      <footer style={{ background: '#0a0a0a', borderTop: `2px solid ${PRIMARY}`, padding: '2rem 2.5rem', display: 'flex', justifyContent: 'space-between', alignItems: 'center', flexWrap: 'wrap', gap: '1rem' }}>
        <span style={{ fontWeight: 900, fontSize: '1rem', color: PRIMARY, textTransform: 'uppercase', letterSpacing: '-0.01em' }}>{{BRAND_NAME}}</span>
        <span style={{ color: '#444', fontSize: '0.75rem' }}>&#169; {year} {{BRAND_NAME}}</span>
      </footer>
    </div>
  );
}
