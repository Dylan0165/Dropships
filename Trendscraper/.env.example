# ═══════════════════════════════════════════════════════════════
# Trendscraper — Environment Configuration
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in the values.

# ── DeepSeek AI ──────────────────────────────────────────────
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# ── CJ Dropshipping ───────────────────────────────────────────
# Get your key at https://developers.cjdropshipping.com
CJ_API_KEY=your_cj_api_key_here

# ── Reddit PRAW ───────────────────────────────────────────────
# Create an app at https://www.reddit.com/prefs/apps (script type)
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=trendscraper/1.0 by dropshipping_tool

# ── Server ────────────────────────────────────────────────────
PORT=8001
